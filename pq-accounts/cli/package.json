{
  "name": "@pq-verifiers/pq-accounts-cli",
  "version": "0.1.0",
  "private": true,
  "description": "CLI for deploying and sending Starknet account transactions with pq-verifiers signature adapters.",
  "type": "module",
  "bin": {
    "pq-accounts": "./dist/index.js",
    "pq-accounts-mcp": "./dist/mcp.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts",
    "mcp": "tsx src/mcp.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "starknet": "^10.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=20"
  }
}
