/// Get even roots of unity for the given polynomial degree
pub fn get_even_roots(degree: u32) -> Span<u16> {
    if degree == 2 {
        phi4_roots_zq.span()
    } else if degree == 4 {
        phi8_roots_zq.span()
    } else if degree == 8 {
        phi16_roots_zq.span()
    } else if degree == 16 {
        phi32_roots_zq.span()
    } else if degree == 32 {
        phi64_roots_zq.span()
    } else if degree == 64 {
        phi128_roots_zq.span()
    } else if degree == 128 {
        phi256_roots_zq.span()
    } else if degree == 256 {
        phi512_roots_zq.span()
    } else if degree == 512 {
        phi1024_roots_zq.span()
    } else {
        panic!("unsupported NTT degree")
    }
}

