        phi32_roots_zq_inv.span()
    } else if degree == 32 {
        phi64_roots_zq_inv.span()
    } else if degree == 64 {
        phi128_roots_zq_inv.span()
    } else if degree == 128 {
        phi256_roots_zq_inv.span()
    } else if degree == 256 {
        phi512_roots_zq_inv.span()
    } else if degree == 512 {
        phi1024_roots_zq_inv.span()
    } else {
        panic!("unsupported NTT degree")
    }
}
