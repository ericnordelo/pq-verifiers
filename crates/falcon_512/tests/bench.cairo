/// Builds the inputs but does NOT verify — the subtraction baseline.
#[test]
fn bench_baseline_falcon_512() {
    let public_key = public_key();
    let signature = signature();
    assert!(public_key.len() == 29 && signature.len() == 58);
}

/// Builds the inputs and verifies a genuine signature — the measured scenario.
#[test]
fn bench_verify_falcon_512() {
    let public_key = public_key();
    let signature = signature();
    let valid = Falcon512Verifier::verify(MSG, public_key.span(), signature.span());
    assert!(valid, "genuine Falcon-512 signature must verify");
}

/// Correctness gate: a tampered signature (msg_point zeroed) must be rejected.
#[test]
fn falcon_512_rejects_tampered() {
    let public_key = public_key();
    let signature = signature();
    let mut bad: Array<felt252> = array![];
    let mut i: u32 = 0;
    while i != 58 {
        if i < 29 {
            bad.append(*signature.at(i));
        } else {
            bad.append(0);
        }
        i += 1;
    }
    let valid = Falcon512Verifier::verify(MSG, public_key.span(), bad.span());
    assert!(!valid, "tampered signature must be rejected");
}
